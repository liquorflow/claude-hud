{
  "name": "claude-hud",
  "version": "0.1.0",
  "description": "A heads-up display (HUD) overlay for Claude AI interactions",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "build": "webpack --config webpack.config.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write src/**/*.js"
  },
  "keywords": [
    "claude",
    "anthropic",
    "hud",
    "overlay",
    "ai",
    "plugin"
  ],
  "author": "personal fork",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jarrodwatts/claude-hud.git"
  },
  "bugs": {
    "url": "https://github.com/jarrodwatts/claude-hud/issues"
  },
  "homepage": "https://github.com/jarrodwatts/claude-hud#readme"
}
